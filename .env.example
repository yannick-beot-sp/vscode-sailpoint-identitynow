# SailPoint ISC tenant name (e.g. "acme" or "acme.identitynow.com")
ISC_TENANT_NAME=your-tenant.identitynow.com

# Personal Access Token (PAT) credentials
ISC_CLIENT_ID=your-client-id
ISC_CLIENT_SECRET=your-client-secret

# Optional: fixed TCP port for the MCP test server (default: 47337)
MCP_TEST_PORT=47337
